# ============================================================
# .env.production.example — Production (Supabase Cloud)
# Set these as environment variables in your hosting platform (Vercel, etc.)
# NEVER commit this file with real values.
# ============================================================

# ---- Supabase (production project) ----
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://aztfeazvyyihzqdypyhc.supabase.co

# Settings → API → Project API keys → anon (public)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YtkSB6CDPeT51BsxsnDAyQ_HjRmhw-9


# ⚠️  Settings → API → Project API keys → service_role (secret)
# NEVER expose this to the browser. Use only in server-side code.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Supabase CLI ----
# Settings → General → Reference ID
SUPABASE_PROJECT_REF=

# supabase.com → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=

# ---- App ----
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_ENV=production
