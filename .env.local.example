# ============================================================
# .env.local.example — Local Development
# Copy to .env.local and fill in the values from `supabase start`
# ============================================================

# ---- Supabase (local) ----
# Shown in output of `supabase start`
NEXT_PUBLIC_SUPABASE_URL=https://aztfeazvyyihzqdypyhc.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YtkSB6CDPeT51BsxsnDAyQ_HjRmhw-9

# ⚠️  SERVER-SIDE ONLY — never use in Client Components or expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# ---- Supabase CLI (for migrations + deploying functions) ----
SUPABASE_PROJECT_REF=          # not needed for local dev
SUPABASE_ACCESS_TOKEN=         # from supabase.com → Account → Access Tokens

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=local
